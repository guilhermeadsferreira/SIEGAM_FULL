# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Configuration (PostgreSQL ETL)
# Local (docker-compose postgres na porta 5433):
DATABASE_URL=postgresql://etl:etl@localhost:5433/etl
# Dentro do Docker (serviço postgres):
# DATABASE_URL=postgresql://etl:etl@postgres:5432/etl

# Environment
ENVIRONMENT=development

# Celery Configuration
CELERY_RETRY_BACKOFF_MAX=60
CELERY_MAX_RETRIES=3

# HTTP Configuration
HTTP_TIMEOUT=30.0

# Redis Configuration
REDIS_URL=redis://localhost:6380/0

# Meteogram Download Configuration
METEOGRAM_BASE_URL=https://tatu.cempa.ufg.br/HST_Meteogramas/
METEOGRAM_BASE_PATH=tmp/meteograms

# ETL Schedule Configuration
ETL_SCHEDULE_HOUR=6
ETL_SCHEDULE_MINUTE=0

# File Validation Configuration
MIN_FILE_SIZE_BYTES=100