# ============================================================
# Variáveis de ambiente — Stack completa (ETL + Notifications)
# Copiar para .env e preencher os valores reais.
#
# DATABASE_URL e REDIS_URL são injetados pelo docker-compose
# via service name. Não precisam estar aqui para Docker.
# Preencha apenas se for rodar algum módulo fora do Docker.
# ============================================================

ENVIRONMENT=development

# ------------------------------------------------------------
# ETL
# ------------------------------------------------------------
METEOGRAM_BASE_URL=https://tatu.cempa.ufg.br/HST_Meteogramas/
METEOGRAM_BASE_PATH=tmp/meteograms
MIN_FILE_SIZE_BYTES=100
HTTP_TIMEOUT=30
CELERY_RETRY_BACKOFF_MAX=60
CELERY_MAX_RETRIES=3
ETL_SCHEDULE_HOUR=6
ETL_SCHEDULE_MINUTE=0

# ------------------------------------------------------------
# Notifications — WhatsApp (Z-API)
# ------------------------------------------------------------
WHATSAPP_INSTANCE=https://api.z-api.io/instances/3ED124F3021B12CEF83C720E11FB8BAA/token/A71D75B9633CAE14BE25BF29/send-text
WHATSAPP_TOKEN=A71D75B9633CAE14BE25BF29
WHATSAPP_CLIENT_TOKEN=F2d7d4bcae54246b49426d3ce61aff7ecS

# ------------------------------------------------------------
# Notifications — SMTP (Email)
# Deixar vazio para desabilitar envio de email.
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# ------------------------------------------------------------
# Notifications — Frontend
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:8080

# ------------------------------------------------------------
# Apenas para execução LOCAL fora do Docker
# (dentro do Docker os valores abaixo são ignorados)
# ------------------------------------------------------------
# DATABASE_URL=postgresql://cempa:cempa@localhost:5432/sigedam
# REDIS_URL=redis://localhost:6379/0
