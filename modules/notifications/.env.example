# Banco de dados (sigedam - mesmo do modulo_usuarios)
DATABASE_URL=postgresql://cempa:cempa@localhost:5432/sigedam

# Redis (fila etl:notifications:ready)
REDIS_URL=redis://localhost:6379/0

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=seu-email@gmail.com
SMTP_PASSWORD=sua-app-password

# Z-API (WhatsApp)
WHATSAPP_INSTANCE=sua-instancia
WHATSAPP_TOKEN=seu-token
WHATSAPP_CLIENT_TOKEN=seu-client-token

# Frontend (para links nos templates)
FRONTEND_URL=http://localhost:8080
